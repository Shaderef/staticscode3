clear;
clc;
j=1;

o=0;
for n = 11:41

L=(80/(n-1)); %feet
tmin=sqrt(0.00868*L)*12;%feet
Smin = 29.25*L; %inches
Sstring = [7.94, 27.7, 70.3, 143, 253];


if Sstring(1) >= Smin
Pilecost = (((13.1*120)/(12^3))*14)*n + 40*n;
elseif Sstring(2) >= Smin
Pilecost = (((30.3*120)/(12^3))*14)*n + 40*n;
elseif Sstring(3) >= Smin
Pilecost = (((56.3*120)/(12^3))*14)*n + 40*n;
elseif Sstring(4) >= Smin
Pilecost = (((90.3*120)/(12^3))*14)*n + 40*n;
else %Sstring(5) >= Smin
Pilecost = (((132*120)/(12^3))*14)*n + 40*n;
end
















%% origin plank cuts
% 8 plank
uses8 = floor(8/(L));
waste8 = 8/(L) - uses8*L;

% 10 plank
uses10 = floor(10/(L));
waste10 = 10/(L) - uses10*L;
% 12 plank
uses12 = floor(L/(12));
waste12 = 12/(L) - uses12*L;

if waste8<=waste10 && waste8<=waste12
   waste = waste8;
uses = uses8;
boardL=8;

elseif waste10<=waste12
   waste = waste10;
uses = uses10;
boardL=10;
else 
   waste = waste12;
uses = uses12;
boardL=12;
end
boardsbottom = ceil((n-1)/uses);




tstring = [13/8,29/8,11/2,15/2,15/2,19/2,23/2];
if tstring(1) >= tmin
h=5;
countup=8;
volwaste = ((waste*L*tstring(1)/12*h)/uses)*(n-1);
Plankvol = L*(tstring(1)/12*h*(n-1));
t=tstring(1);
elseif tstring(2) >= tmin
h=5;
countup=8;
volwaste = ((waste*L*tstring(2)/12*h)/uses)*(n-1);
Plankvol = L*(tstring(2)/12*h*(n-1));
t=tstring(2);
elseif tstring(3) >= tmin
h=5;
countup=8;
volwaste = ((waste*L*tstring(3)/12*h)/uses)*(n-1);
Plankvol = L*(tstring(3)/12*h*(n-1));
t=tstring(3);
elseif tstring(4) >= tmin
h=5;
countup=8;
volwaste = ((waste*L*tstring(4)/12*h)/uses)*(n-1);
Plankvol = L*(tstring(4)/12*h*(n-1));
t=tstring(4);
elseif tstring(5) >= tmin
h=62/12;
countup=4;
volwaste = ((waste*L*tstring(5)/12*h)/uses)*(n-1);
Plankvol = L*(tstring(5)/12*h*(n-1));
t=tstring(5);
else %tstring(6) >= tmin
h=62/12;
countup=4;
volwaste = ((waste*L*tstring(6)/12*h)/uses)*(n-1);
Plankvol = L*(tstring(6)/12*h*(n-1));
t=tstring(6);
end
boardstotal = boardsbottom*countup
boardvol= boardstotal*t*h*boardL/12/12
boardscost = boardvol*14
Plankcost = (Plankvol+volwaste)*14;

y(j) = Pilecost + Plankcost;
x(j) = n;
j=j+1;
end
























% --- Find Minimum Cost ---
[minCost, minIndex] = findMinCost(y);
minX = x(minIndex);
% --- Display Results ---
fprintf('\nResults:\n');
fprintf(' Minimum cost : %.4f\n', minCost);
fprintf(' Ordered pair : (%.4f, %.4f)\n', minX, minCost);
% --- Plot ---
figure;
plot(x, y, '-o', 'LineWidth', 1.5, 'MarkerFaceColor', 'b');
hold on;
plot(minX, minCost, 'ro', 'MarkerSize', 10, 'MarkerFaceColor', 'r', 'DisplayName', ...
sprintf('Min: (%.2f, %.2f)', minX, minCost));
text(minX, minCost, sprintf(' Min: (%.2f, %.2f)', minX, minCost), ...
'FontSize', 10, 'Color', 'red', 'VerticalAlignment', 'bottom');
xlabel('Piles');
ylabel('Cost (Y)');
title('Cost vs X');
legend('Cost data', 'Minimum cost', 'Location', 'best');
grid on;
hold off;
% =========================================================
% Local function - findMinCost
% =========================================================
function [minCost, minIndex] = findMinCost(costList)
minCost = costList(1);
minIndex = 1;
for i = 2 : length(costList)
if costList(i) < minCost
minCost = costList(i);
minIndex = i;


end
end
end
