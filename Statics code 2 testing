clear;
clc;
j=1;
o=0;
for n = 11:41

L=(80/(n-1)); %feet
tmin=sqrt(0.00868*L)*12; %feet
Smin = 29.25*L; %inches
Sstring = [7.94, 27.7, 70.3, 143, 253];


if Sstring(1) >= Smin
Pilecost = (((13.1*120)/12^3)*14)*n + 40*n;

elseif Sstring(2) >= Smin
Pilecost = (((30.3*120)/12^3)*14)*n + 40*n;
elseif Sstring(3) >= Smin
Pilecost = (((56.3*120)/12^3)*14)*n + 40*n;
elseif Sstring(4) >= Smin
Pilecost = (((90.3*120)/12^3)*14)*n + 40*n;

else %Sstring(5) >= Smin
Pilecost = (((132*120)/12^3)*14)*n + 40*n;
end

%% origin plank cuts
% 8 plank
uses8 = floor(L/(8));
waste8 = L/(8) - uses8;

% 10 plank
uses10 = floor(L/(10));
waste10 = L/(10) - uses10;
% 12 plank
uses12 = floor(L/(12));
waste12 = L/(12) - uses12;

if waste8<=waste10 && waste8<=waste12
   plankslength = 80/8;
Lplank = 8;
elseif waste10<=waste12
   plankslength = 80/10;
Lplank = 10;
else 
   plankslength = 80/12;
Lplank = 12;
end

tstring = [13/8,29/8,11/2,15/2,15/2,19/2,23/2];
if tstring(1) >= tmin

Plankvol = Lplank*(tstring(1)/12)*5*(n-1);

elseif tstring(2) >= tmin
Plankvol = Lplank*(tstring(2)/12)*5*(n-1);
elseif tstring(3) >= tmin
Plankvol = Lplank*(tstring(3)/12)*5*(n-1);
elseif tstring(4) >= tmin
Plankvol = Lplank*(tstring(4)/12)*5*(n-1);
elseif tstring(5) >= tmin
Plankvol = Lplank*(tstring(5)/12)*5*(n-1);
else %tstring(6) >= tmin
Plankvol = Lplank*(tstring(6)/12)*5*(n-1);
end
Plankcost = Plankvol*14;

y(j) = Pilecost + Plankcost;
x(j) = n;
j=j+1;
end

% --- Find Minimum Cost ---
[minCost, minIndex] = findMinCost(y);
minX = x(minIndex);
% --- Display Results ---
fprintf('\nResults:\n');
fprintf(' Minimum cost : %.4f\n', minCost);
fprintf(' Ordered pair : (%.4f, %.4f)\n', minX, minCost);
% --- Plot ---
figure;
plot(x, y, '-o', 'LineWidth', 1.5, 'MarkerFaceColor', 'b');
hold on;
plot(minX, minCost, 'ro', 'MarkerSize', 10, 'MarkerFaceColor', 'r', 'DisplayName', ...
sprintf('Min: (%.2f, %.2f)', minX, minCost));
text(minX, minCost, sprintf(' Min: (%.2f, %.2f)', minX, minCost), ...
'FontSize', 10, 'Color', 'red', 'VerticalAlignment', 'bottom');
xlabel('X');
ylabel('Cost (Y)');
title('Cost vs X');
legend('Cost data', 'Minimum cost', 'Location', 'best');
grid on;
hold off;
% =========================================================
% Local function - findMinCost
% =========================================================
function [minCost, minIndex] = findMinCost(costList)
minCost = costList(1);
minIndex = 1;
for i = 2 : length(costList)
if costList(i) < minCost
minCost = costList(i);
minIndex = i;

end
end
end
